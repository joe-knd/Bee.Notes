<UserControl
    x:Class="WpfNotes.Features.Chat.ChatView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WpfNotes.Features.Chat"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <UserControl.Resources>
        <local:HexToBrushConverter x:Key="HexToBrush" />
    </UserControl.Resources>

    <DockPanel>
        <!--  ═══ Connection bar ═══  -->
        <Border
            Padding="12,8"
            BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
            BorderThickness="0,0,0,1"
            DockPanel.Dock="Top">
            <StackPanel>
                <WrapPanel VerticalAlignment="Center">
                    <TextBlock
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        Text="Name:" />
                    <TextBox
                        Width="100"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="IsEnabled" Value="False" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <TextBlock
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        Text="Password:" />
                    <PasswordBox
                        x:Name="PasswordInput"
                        Width="90"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        PasswordChanged="PasswordInput_PasswordChanged">
                        <PasswordBox.Style>
                            <Style TargetType="PasswordBox" BasedOn="{StaticResource {x:Type PasswordBox}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="IsEnabled" Value="False" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </PasswordBox.Style>
                    </PasswordBox>

                    <Button
                        Margin="0,0,4,0"
                        Padding="8,4"
                        VerticalAlignment="Center"
                        Command="{Binding HostCommand}"
                        Content="🖧 Host" />

                    <Rectangle
                        Width="1"
                        Height="20"
                        Margin="8,0"
                        VerticalAlignment="Center"
                        Fill="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" />

                    <TextBlock
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        Text="IP:" />
                    <TextBox
                        Width="110"
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        Text="{Binding HostAddress, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock
                        Margin="4,0,4,0"
                        VerticalAlignment="Center"
                        Text="Port:" />
                    <TextBox
                        Width="50"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" />
                    <Button
                        Margin="0,0,4,0"
                        Padding="8,4"
                        VerticalAlignment="Center"
                        Command="{Binding JoinCommand}"
                        Content="🔗 Join" />

                    <Rectangle
                        Width="1"
                        Height="20"
                        Margin="8,0"
                        VerticalAlignment="Center"
                        Fill="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" />

                    <Button
                        Padding="8,4"
                        VerticalAlignment="Center"
                        Command="{Binding DisconnectCommand}"
                        Content="Disconnect" />
                </WrapPanel>

                <TextBlock
                    Margin="0,4,0,0"
                    FontSize="10"
                    Opacity="0.5"
                    Text="{Binding Status}" />
            </StackPanel>
        </Border>

        <!--  ═══ Message input ═══  -->
        <Border
            Padding="12,8"
            BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
            <DockPanel>
                <Button
                    Margin="8,0,0,0"
                    Padding="12,6"
                    Command="{Binding SendMessageCommand}"
                    Content="Send"
                    DockPanel.Dock="Right" />
                <TextBox
                    x:Name="MessageInput"
                    VerticalContentAlignment="Center"
                    KeyDown="MessageInput_KeyDown"
                    Text="{Binding MessageText, UpdateSourceTrigger=PropertyChanged}" />
            </DockPanel>
        </Border>

        <!--  ═══ Messages ═══  -->
        <ScrollViewer x:Name="MessagesScroll" VerticalScrollBarVisibility="Auto">
            <ItemsControl Margin="12,8" ItemsSource="{Binding MessageGroups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,6,0,0">
                            <!--  System message (join/leave)  -->
                            <TextBlock
                                x:Name="SystemMsg"
                                Margin="0,4"
                                HorizontalAlignment="Center"
                                FontSize="11"
                                FontStyle="Italic"
                                Opacity="0.5"
                                Text="{Binding Messages[0].Text}"
                                Visibility="Collapsed" />

                            <!--  Chat group  -->
                            <StackPanel x:Name="GroupPanel" HorizontalAlignment="Left">
                                <!--  Sender name (once per group)  -->
                                <TextBlock
                                    Margin="4,0,4,2"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="{Binding Color, Converter={StaticResource HexToBrush}, ConverterParameter=solid}"
                                    Text="{Binding Sender}" />

                                <!--  Individual message bubbles  -->
                                <ItemsControl ItemsSource="{Binding Messages}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border
                                                x:Name="MsgBubble"
                                                MaxWidth="500"
                                                Margin="0,1"
                                                Padding="10,6"
                                                HorizontalAlignment="Left"
                                                Background="{Binding DataContext.Color, Converter={StaticResource HexToBrush}, RelativeSource={RelativeSource AncestorType=StackPanel}}"
                                                CornerRadius="4,12,12,4">
                                                <DockPanel>
                                                    <TextBlock
                                                        Margin="8,0,0,0"
                                                        VerticalAlignment="Bottom"
                                                        DockPanel.Dock="Right"
                                                        FontSize="9"
                                                        Opacity="0.5"
                                                        Text="{Binding Timestamp, StringFormat='{}{0:h:mm tt}'}" />
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        Text="{Binding Text}"
                                                        TextWrapping="Wrap" />
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsSystemMessage}" Value="True">
                                <Setter TargetName="SystemMsg" Property="Visibility" Value="Visible" />
                                <Setter TargetName="GroupPanel" Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsOwnMessage}" Value="True">
                                <Setter TargetName="GroupPanel" Property="HorizontalAlignment" Value="Right" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
