<UserControl
    x:Class="WpfNotes.Features.Home.HomeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WpfNotes.Features.Home"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <DockPanel Margin="16">
        <TextBlock DockPanel.Dock="Top" Text="Recent Notes"
                   FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12" />

        <TextBlock DockPanel.Dock="Top"
                   Text="No notes yet — click New or Open File to get started."
                   Opacity="0.6"
                   FontStyle="Italic" Margin="0,20,0,0">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding RecentNotes.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding RecentNotes}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="12" Margin="4"
                                Width="210" Height="160"
                                Cursor="Hand">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Setter Property="CornerRadius" Value="6" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#18FFFFFF" />
                                            <Setter Property="BorderBrush" Value="DarkGoldenrod" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftDoubleClick"
                                              Command="{Binding DataContext.OpenNoteCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              CommandParameter="{Binding}" />
                            </Border.InputBindings>
                            <DockPanel>
                                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                                    <Button DockPanel.Dock="Right" Content="✕"
                                            FontSize="10" Padding="4,1"
                                            VerticalAlignment="Top"
                                            Command="{Binding DataContext.DeleteNoteCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" />
                                    <TextBlock Text="{Binding Title}"
                                               FontWeight="Bold" FontSize="14"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center" />
                                </DockPanel>
                                <TextBlock DockPanel.Dock="Bottom"
                                           Text="{Binding LastModified, StringFormat='{}{0:MMM dd, yyyy  h:mm tt}'}"
                                           FontSize="10" Opacity="0.6"
                                           Margin="0,6,0,0" />
                                <TextBlock Text="{Binding Preview}" TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"
                                           Opacity="0.6" FontSize="11" />
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
