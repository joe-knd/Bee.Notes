<Window
    x:Class="WpfNotes.AboutWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="About Bee! Notes"
    Icon="/Bee! Solutions logo 1.png"
    Width="340"
    SizeToContent="Height"
    WindowStartupLocation="CenterOwner"
    WindowStyle="SingleBorderWindow"
    ResizeMode="NoResize">
    <StackPanel Margin="24">
        <Image
            Source="/Bee! Solutions logo 1.png"
            Width="100"
            Height="100"
            Stretch="Uniform"
            RenderOptions.BitmapScalingMode="HighQuality"
            HorizontalAlignment="Center"
            Margin="0,0,0,16" />

        <TextBlock
            HorizontalAlignment="Center"
            FontSize="20"
            FontWeight="Bold">
            <Run Text="Bee! " /><Run Text="Notes" FontStyle="Italic" />
        </TextBlock>

        <TextBlock
            x:Name="VersionText"
            HorizontalAlignment="Center"
            Margin="0,6,0,0"
            FontSize="13"
            Foreground="Gray" />

        <TextBlock
            HorizontalAlignment="Center"
            Margin="0,16,0,0"
            FontSize="12"
            Foreground="Gray"
            Text="A lightweight encrypted notes app with peer-to-peer chat."
            TextAlignment="Center"
            TextWrapping="Wrap" />

        <Button
            Content="OK"
            Width="80"
            Margin="0,20,0,0"
            HorizontalAlignment="Center"
            IsDefault="True"
            IsCancel="True"
            Click="OK_Click" />
    </StackPanel>
</Window>
